<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.hotel.controller.MainController"
            prefHeight="600.0" 
            prefWidth="1000.0"
            stylesheets="@style.css">

    <!-- LEFT: Sidebar Fixa -->
    <left>
        <VBox spacing="8" prefWidth="220" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="25" right="12" bottom="20" left="12"/>
            </padding>

            <!-- Título -->
            <Label text="Hotel Meia Boca Juniors" 
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 0 0 15 0;"/>

            <!-- Botões de Navegação -->
            <Button fx:id="btnDashboard" 
                    text="🏠 Dashboard" 
                    onAction="#openDashboard" 
                    prefWidth="196" 
                    styleClass="sidebar-button"/>

            <Button fx:id="btnGuests" 
                    text="👥 Hóspedes" 
                    onAction="#openGuestsScreen" 
                    prefWidth="196" 
                    styleClass="sidebar-button"/>

            <Button fx:id="btnRooms" 
                    text="🛏️ Quartos" 
                    onAction="#openRoomsScreen" 
                    prefWidth="196" 
                    styleClass="sidebar-button"/>

            <Button fx:id="btnReservations" 
                    text="📅 Reservas" 
                    onAction="#openReservationsScreen" 
                    prefWidth="196" 
                    styleClass="sidebar-button"/>

            <Separator style="-fx-background-color: #34495e;"/>

            <!-- Logout -->
            <Button text="🚪 Logout" 
                    onAction="#logout" 
                    prefWidth="196" 
                    styleClass="sidebar-button-logout"/>
        </VBox>
    </left>

    <!-- CENTER: Área dinâmica de conteúdo -->
    <center>
        <StackPane fx:id="contentArea" />
    </center>
</BorderPane>