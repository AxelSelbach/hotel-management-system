<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.hotel.controller.ReservationController"
            prefHeight="650.0"
            prefWidth="1000.0"
            stylesheets="@style.css">

    <!-- TOP: Formulário de Nova Reserva -->
    <top>
        <GridPane hgap="20.0" vgap="12.0" styleClass="card">
            <padding>
                <Insets top="20.0" right="30.0" bottom="20.0" left="30.0"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints percentWidth="30.0"/>
                <ColumnConstraints percentWidth="70.0"/>
            </columnConstraints>

            <children>
                <Label text="Hóspede:" styleClass="label-bold" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cbGuest" promptText="Selecione o hóspede" 
                          prefWidth="320.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Quarto:" styleClass="label-bold" GridPane.rowIndex="1"/>
                <ComboBox fx:id="cbRoom" promptText="Selecione o quarto" 
                          prefWidth="320.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Check-In:" styleClass="label-bold" GridPane.rowIndex="2"/>
                <DatePicker fx:id="dpCheckIn" prefWidth="320.0" 
                            GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Check-Out:" styleClass="label-bold" GridPane.rowIndex="3"/>
                <DatePicker fx:id="dpCheckOut" prefWidth="320.0" 
                            GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Valor Total:" styleClass="label-bold" GridPane.rowIndex="4"/>
                <Label fx:id="lblTotal" text="R$ 0,00" styleClass="lblTotal"
                       style="-fx-font-size: 18px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"
                       GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </children>
        </GridPane>
    </top>

    <!-- CENTER: Tabela de Reservas -->
    <center>
        <VBox>
            <Label text="Reservas Registradas" 
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 0 8 15;"/>

            <TableView fx:id="tableReservations" prefHeight="300.0">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID"/>
                    <TableColumn fx:id="colGuest" prefWidth="220" text="Hóspede"/>
                    <TableColumn fx:id="colRoom" prefWidth="100" text="Quarto"/>
                    <TableColumn fx:id="colCheckIn" prefWidth="110" text="Check-In"/>
                    <TableColumn fx:id="colCheckOut" prefWidth="110" text="Check-Out"/>
                    <TableColumn fx:id="colTotal" prefWidth="100" text="Total"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- BOTTOM: Botões -->
    <bottom>
        <HBox spacing="12.0" alignment="CENTER" prefHeight="70.0">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="10.0"/>
            </padding>
            <children>
                <Button fx:id="btnCheckIn" text="✅ Check-In" 
                        onAction="#performCheckIn" styleClass="button-success"/>
                
                <Button fx:id="btnCheckOut" text="🚪 Check-Out" 
                        onAction="#performCheckOut" styleClass="button-primary"/>
                
                <Button fx:id="btnCancel" text="❌ Limpar" 
                        onAction="#cancelReservation" styleClass="button-danger"/>
                
                <Button text="🔄 Atualizar" onAction="#refreshReservations"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>