<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.hotel.controller.LoginController"
            prefHeight="500.0" 
            prefWidth="700.0"
            style="-fx-background-color: #f4f6f9;"
            stylesheets="@style.css">

    <children>
        <!-- Container central do login -->
        <VBox layoutX="200.0" 
              layoutY="100.0" 
              prefHeight="280.0" 
              prefWidth="320.0" 
              spacing="15.0" 
              alignment="CENTER"
              styleClass="card">

            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
            </padding>

            <children>
                <!-- Título -->
                <Label text="Hotel Meia Boca Juniors" 
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <Label text="Faça seu login para continuar" 
                       style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-padding: 0 0 10 0;"/>

                <!-- Campos -->
                <Label text="E-mail" styleClass="label-bold"/>
                <TextField fx:id="txtEmail" 
                           promptText="email@exemplo.com" />

                <Label text="Senha" styleClass="label-bold"/>
                <PasswordField fx:id="txtPassword" />

                <!-- Mensagem de erro -->
                <Label fx:id="lblError" 
                       textFill="#e74c3c" 
                       style="-fx-font-size: 13px;"
                       visible="false" />

                <!-- Botão Login -->
                <Button fx:id="btnLogin" 
                        text="Entrar" 
                        onAction="#handleLogin"
                        prefWidth="200.0"
                        styleClass="button-primary"
                        defaultButton="true" />

            </children>
        </VBox>
    </children>
</AnchorPane>