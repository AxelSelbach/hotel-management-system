<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.hotel.controller.DashboardController"
            prefHeight="550.0" 
            prefWidth="900.0"
            stylesheets="@../style.css">

    <center>
        <VBox spacing="20.0" alignment="CENTER">
            <padding>
                <Insets top="40.0" bottom="20.0"/>
            </padding>
            
            <Label text="📊 Dashboard - Ocupação do Hotel" 
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <PieChart fx:id="occupancyChart" 
                      title="Taxa de Ocupação dos Quartos"
                      prefHeight="320.0" 
                      prefWidth="620.0" />

            <HBox spacing="40.0" alignment="CENTER">
                <Label fx:id="lblTotalRooms" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="lblOccupied" style="-fx-font-size: 16px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                <Label fx:id="lblAvailable" style="-fx-font-size: 16px; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>
                <Label fx:id="lblOccupancyRate" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>