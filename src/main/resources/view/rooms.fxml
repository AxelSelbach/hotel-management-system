<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.hotel.controller.RoomController"
            prefHeight="550.0" 
            prefWidth="950.0"
            stylesheets="@style.css">

    <!-- TOP: Filtros -->
    <top>
        <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="header">
            <padding>
                <Insets bottom="12.0" left="15.0" right="15.0" top="12.0"/>
            </padding>
            <children>
                <Label text="Tipo:" styleClass="label-bold"/>
                <ComboBox fx:id="cbType" prefWidth="160.0" promptText="Todos"/>

                <Label text="Status:" styleClass="label-bold"/>
                <ComboBox fx:id="cbStatus" prefWidth="160.0" promptText="Todos"/>
                
                <Button text="Filtrar" fx:id="btnFilter" onAction="#filterRooms"/>
                <Button text="Limpar Filtros" fx:id="btnClearFilter" onAction="#clearFilters"/>
            </children>
        </HBox>
    </top>

    <!-- CENTER: Tabela de Quartos -->
    <center>
        <TableView fx:id="tableRooms">
            <columns>
                <TableColumn fx:id="colId"     prefWidth="60.0"  text="ID" />
                <TableColumn fx:id="colNumber" prefWidth="100.0" text="Número" />
                <TableColumn fx:id="colType"   prefWidth="120.0" text="Tipo" />
                <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
                <TableColumn fx:id="colPrice"  prefWidth="110.0" text="Valor Diária" />
            </columns>
        </TableView>
    </center>

    <!-- RIGHT: Formulário de Cadastro/Edição -->
    <right>
        <VBox spacing="12.0" prefWidth="220.0" styleClass="card">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
            <children>
                <Label text="Cadastro de Quarto" styleClass="title-label"/>

                <Label text="Número do Quarto"/>
                <TextField fx:id="txtNumber" promptText="Ex: 101"/>

                <Label text="Tipo"/>
                <ComboBox fx:id="cbTypeForm" prefWidth="190.0"/>

                <Label text="Valor Diária (R$)"/>
                <TextField fx:id="txtPrice" promptText="150.00"/>

                <!-- Botões -->
                <HBox spacing="10.0" alignment="CENTER">
                    <Button fx:id="btnSave"   text="Salvar"   onAction="#saveRoom"   styleClass="button-primary"/>
                    <Button fx:id="btnEdit"   text="Editar"  onAction="#editRoom"   styleClass="button-primary"/>
                    <Button fx:id="btnDelete" text="Excluir" onAction="#deleteRoom" styleClass="button-danger"/>
                </HBox>
            </children>
        </VBox>
    </right>
</BorderPane>