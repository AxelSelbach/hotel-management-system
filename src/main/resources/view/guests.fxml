<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="br.com.hotel.controller.GuestController"
            prefHeight="500.0" 
            prefWidth="800.0"
            stylesheets="@../style.css">

    <!-- TOP: Barra de Busca -->
    <top>
        <HBox prefHeight="60.0" spacing="10.0" alignment="CENTER_LEFT">
            <padding>
                <Insets bottom="10.0" left="15.0" right="15.0" top="15.0"/>
            </padding>
            <children>
                <Label text="Buscar por CPF:" styleClass="label-bold"/>
                <TextField fx:id="txtCpfSearch" 
                           promptText="Digite o CPF" 
                           prefWidth="200.0"/>
                <Button text="Buscar" fx:id="btnSearch" onAction="#searchGuest"/>
            </children>
        </HBox>
    </top>

    <!-- CENTER: Tabela -->
    <center>
        <TableView fx:id="tableGuests" 
                   prefHeight="300.0">
            <columns>
                <TableColumn fx:id="colID"    prefWidth="60.0"  text="ID" />
                <TableColumn fx:id="colName"  prefWidth="180.0" text="Nome" />
                <TableColumn fx:id="colCPF"   prefWidth="120.0" text="CPF" />
                <TableColumn fx:id="colPhone" prefWidth="130.0" text="Telefone" />
                <TableColumn fx:id="colEmail" prefWidth="220.0" text="E-mail" />
            </columns>
        </TableView>
    </center>

    <!-- BOTTOM: Botões de Ação -->
    <bottom>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="10.0"/>
            </padding>
            <children>
                <Button fx:id="btnNew"    text="Novo"    onAction="#newGuest"    styleClass="button-primary"/>
                <Button fx:id="btnEdit"   text="Editar"  onAction="#editGuest"   styleClass="button-primary"/>
                <Button fx:id="btnDelete" text="Excluir" onAction="#deleteGuest" styleClass="button-danger"/>
            </children>
        </HBox>
    </bottom>
</BorderPane>